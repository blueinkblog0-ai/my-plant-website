<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>بستاني | عالم الزراعة المنزلية</title>
<link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;800;900&display=swap" rel="stylesheet">
<style>
/* ═══════════════════════════════════════════
   ROOT & RESET
═══════════════════════════════════════════ */
:root {
  --green-dark: #1a3a0a;
  --green-mid:  #2d5c14;
  --green-light:#4a8c2a;
  --accent:     #a8e063;
  --accent-hover:#95cc54;
  --accent2:    #f9c74f;
  --accent3:    #f94144;
  --text-main:  #1a2e0a;
  --text-soft:  #4a6630;
  --card-radius:22px;
  --nav-h: 72px;
  --transition: 0.35s cubic-bezier(0.4,0,0.2,1);
  --shadow: 0 10px 30px rgba(0,0,0,0.08);
}

*, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }

html { scroll-behavior: smooth; }

body {
  font-family: 'Tajawal', sans-serif;
  background: #f0f5e8;
  color: var(--text-main);
  min-height: 100vh;
  display: flex; flex-direction: column;
  overflow-x: hidden;
}

/* ═══════════════════════════════════════════
   NAVIGATION
═══════════════════════════════════════════ */
nav {
  position: fixed;
  top: 0; left: 0; right: 0;
  height: var(--nav-h);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 36px;
  background: rgba(26, 58, 10, 0.92);
  backdrop-filter: blur(16px);
  border-bottom: 1px solid rgba(168,224,99,0.15);
  transition: box-shadow 0.3s;
}

nav.scrolled { box-shadow: 0 4px 30px rgba(0,0,0,0.3); }

.nav-logo {
  display: flex;
  align-items: center;
  gap: 10px;
  text-decoration: none;
  cursor: pointer;
}
.nav-logo .logo-icon { font-size: 2rem; animation: leafSway 4s ease-in-out infinite; display:inline-block; transform-origin: bottom center; }
@keyframes leafSway { 0%,100%{transform:rotate(-6deg)} 50%{transform:rotate(6deg)} }
.nav-logo .logo-text { font-size: 1.6rem; font-weight: 900; color: #fff; letter-spacing: -0.5px; }
.nav-logo .logo-text span { color: var(--accent); }

.nav-links {
  display: flex;
  gap: 4px;
  list-style: none;
}
.nav-links li button {
  background: none;
  border: none;
  cursor: pointer;
  font-family: 'Tajawal', sans-serif;
  font-size: 0.95rem;
  font-weight: 600;
  color: rgba(255,255,255,0.7);
  padding: 8px 14px;
  border-radius: 10px;
  transition: var(--transition);
  position: relative;
}
.nav-links li button::after {
  content:'';
  position:absolute;
  bottom:4px; left:50%; right:50%;
  height:2px;
  background: var(--accent);
  border-radius:1px;
  transition: var(--transition);
}
.nav-links li button:hover, .nav-links li button.active {
  color: #fff;
  background: rgba(168,224,99,0.1);
}
.nav-links li button:hover::after, .nav-links li button.active::after {
  left:14px; right:14px;
}

.nav-cta {
  background: linear-gradient(135deg, var(--accent), #7ac93a) !important;
  color: var(--green-dark) !important;
  font-weight: 800 !important;
  padding: 8px 20px !important;
  border-radius: 50px !important;
}
.nav-cta::after { display:none !important; }
.nav-cta:hover { transform: scale(1.05); box-shadow: 0 4px 16px rgba(168,224,99,0.4) !important; }

/* ═══════════════════════════════════════════
   PAGE SYSTEM
═══════════════════════════════════════════ */
.page {
  display: none;
  min-height: 100vh;
  padding-top: var(--nav-h);
  flex: 1;
  animation: pageIn 0.6s cubic-bezier(0.23, 1, 0.32, 1) both;
}
.page.active { display: block; }
@keyframes pageIn { from{opacity:0;transform:translateY(16px)} to{opacity:1;transform:translateY(0)} }

/* ═══════════════════════════════════════════
   PAGE 1 — HOME / HERO
═══════════════════════════════════════════ */
.hero {
  min-height: calc(100vh - var(--nav-h));
  background: linear-gradient(145deg, #1a3a0a 0%, #2d5c14 40%, #1e4a0c 100%);
  display: grid;
  grid-template-columns: 1fr 1fr;
  align-items: center;
  padding: 60px 60px 60px 80px;
  position: relative;
  overflow: hidden;
  gap: 40px;
}

.hero::before {
  content:'';
  position:absolute;
  inset:0;
  background:
    radial-gradient(ellipse at 80% 50%, rgba(168,224,99,0.08) 0%, transparent 60%),
    radial-gradient(ellipse at 10% 80%, rgba(249,199,79,0.05) 0%, transparent 50%);
}

.hero-pattern {
  position:absolute;
  inset:0;
  background-image: repeating-linear-gradient(
    45deg,
    transparent,
    transparent 40px,
    rgba(255,255,255,0.01) 40px,
    rgba(255,255,255,0.01) 41px
  );
}

.hero-text { position:relative; z-index:1; }

.hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: rgba(168,224,99,0.15);
  border: 1px solid rgba(168,224,99,0.3);
  border-radius: 50px;
  padding: 6px 16px;
  margin-bottom: 24px;
  font-size: 0.8rem;
  font-weight: 700;
  color: var(--accent);
  letter-spacing: 1.5px;
}
.hero-badge .pulse-dot { width:7px;height:7px;background:var(--accent);border-radius:50%;animation:pulse 2s infinite; }
@keyframes pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:0.4;transform:scale(0.6)} }

.hero h1 {
  font-size: clamp(2.4rem, 4.5vw, 3.8rem);
  font-weight: 900;
  color: #fff;
  line-height: 1.2;
  margin-bottom: 20px;
  text-shadow: 0 4px 24px rgba(0,0,0,0.3);
}
.hero h1 em { color: var(--accent); font-style:normal; }

.hero p {
  font-size: 1.1rem;
  color: rgba(255,255,255,0.65);
  line-height: 1.8;
  max-width: 440px;
  margin-bottom: 36px;
}

.hero-btns { display:flex; gap:14px; flex-wrap:wrap; }

.btn-primary {
  background: linear-gradient(135deg, var(--accent), #7ac93a);
  color: var(--green-dark);
  border: none;
  cursor: pointer;
  font-family: 'Tajawal', sans-serif;
  font-size: 1rem;
  font-weight: 800;
  padding: 14px 32px;
  border-radius: 50px;
  transition: var(--transition);
  box-shadow: 0 4px 20px rgba(168,224,99,0.35);
}
.btn-primary:hover { transform: translateY(-3px); box-shadow: 0 8px 30px rgba(168,224,99,0.5); }

.btn-secondary {
  background: rgba(255,255,255,0.1);
  color: #fff;
  border: 1px solid rgba(255,255,255,0.25);
  cursor: pointer;
  font-family: 'Tajawal', sans-serif;
  font-size: 1rem;
  font-weight: 700;
  padding: 14px 32px;
  border-radius: 50px;
  transition: var(--transition);
  backdrop-filter: blur(8px);
}
.btn-secondary:hover { background: rgba(255,255,255,0.18); transform: translateY(-3px); }

.hero-stats {
  display: flex;
  gap: 30px;
  margin-top: 44px;
  padding-top: 32px;
  border-top: 1px solid rgba(255,255,255,0.1);
}
.stat { text-align:center; }
.stat-num { font-size: 2rem; font-weight: 900; color: var(--accent); }
.stat-label { font-size: 0.8rem; color: rgba(255,255,255,0.5); font-weight: 500; margin-top: 2px; }

/* Hero visual side */
.hero-visual {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16px;
}

.hero-orbit {
  position: relative;
  width: 340px;
  height: 340px;
}
.orbit-center {
  position:absolute;
  top:50%;left:50%;
  transform:translate(-50%,-50%);
  width:130px;height:130px;
  background: radial-gradient(circle, rgba(168,224,99,0.2), rgba(168,224,99,0.05));
  border-radius:50%;
  display:flex;align-items:center;justify-content:center;
  font-size:4rem;
  border:2px solid rgba(168,224,99,0.3);
  box-shadow: 0 0 60px rgba(168,224,99,0.15), inset 0 0 30px rgba(168,224,99,0.05);
  animation: orbitPulse 3s ease-in-out infinite;
}
@keyframes orbitPulse { 0%,100%{transform:translate(-50%,-50%) scale(1)} 50%{transform:translate(-50%,-50%) scale(1.04)} }

.orbit-item {
  position:absolute;
  width:68px;height:68px;
  background: rgba(255,255,255,0.1);
  backdrop-filter:blur(8px);
  border:1px solid rgba(255,255,255,0.2);
  border-radius:50%;
  display:flex;align-items:center;justify-content:center;
  font-size:1.8rem;
  box-shadow:0 4px 20px rgba(0,0,0,0.2);
  transition: transform 0.3s;
  cursor:default;
  animation: floatItem 6s ease-in-out infinite;
}
.orbit-item:hover { transform: scale(1.2) !important; }
.orbit-item:nth-child(2)  { top:0%;   left:50%; transform:translate(-50%,-50%); animation-delay:0s; }
.orbit-item:nth-child(3)  { top:25%;  right:-5%; animation-delay:0.5s; }
.orbit-item:nth-child(4)  { top:75%;  right:-5%; animation-delay:1s; }
.orbit-item:nth-child(5)  { top:100%; left:50%; transform:translate(-50%,-50%); animation-delay:1.5s; }
.orbit-item:nth-child(6)  { top:75%;  left:-5%; animation-delay:2s; }
.orbit-item:nth-child(7)  { top:25%;  left:-5%; animation-delay:2.5s; }
@keyframes floatItem { 0%,100%{margin-top:0} 50%{margin-top:-8px} }

/* ═══════════════════════════════════════════
   PAGE 2 — VEGETABLES
═══════════════════════════════════════════ */
.page-header {
  background: linear-gradient(135deg, var(--green-dark) 0%, var(--green-mid) 100%);
  padding: 60px 60px 50px;
  text-align: center;
  position:relative;overflow:hidden;
}
.page-header::after {
  content:'';position:absolute;inset:0;
  background: radial-gradient(ellipse at 50% 100%, rgba(168,224,99,0.1) 0%, transparent 60%);
}
.page-header h2 { font-size:2.6rem;font-weight:900;color:#fff;position:relative;z-index:1; }
.page-header h2 span { color:var(--accent); }
.page-header p { color:rgba(255,255,255,0.6);margin-top:10px;font-size:1.05rem;position:relative;z-index:1; }

/* Filter tabs */
.filter-tabs {
  display: flex;
  gap: 10px;
  justify-content: center;
  padding: 30px 40px 20px;
  flex-wrap: wrap;
}
.filter-btn {
  background: #fff;
  border: 2px solid transparent;
  cursor: pointer;
  font-family:'Tajawal',sans-serif;
  font-size:0.9rem;
  font-weight:700;
  color: var(--text-soft);
  padding: 8px 20px;
  border-radius: 50px;
  transition: var(--transition);
  box-shadow: 0 2px 8px rgba(0,0,0,0.06);
}
.filter-btn:hover { border-color: var(--green-light); color: var(--green-dark); }
.filter-btn.active {
  background: var(--green-dark);
  color: #fff;
  border-color: var(--green-dark);
  box-shadow: 0 4px 16px rgba(45,92,20,0.35);
}

.search-container {
  max-width: 600px;
  margin: 0 auto 30px;
  padding: 0 20px;
  position: relative;
  z-index: 10;
}
.search-input {
  width: 100%;
  padding: 16px 50px 16px 20px;
  border-radius: 50px;
  border: 2px solid rgba(26, 58, 10, 0.1);
  background: #fff;
  font-family: inherit;
  font-size: 1rem;
  box-shadow: var(--shadow);
  transition: var(--transition);
}
.search-input:focus {
  outline: none;
  border-color: var(--accent);
  box-shadow: 0 0 0 4px rgba(168,224,99,0.2);
}
.search-icon {
  position: absolute;
  top: 50%;
  right: 40px;
  transform: translateY(-50%);
  font-size: 1.2rem;
  pointer-events: none;
  opacity: 0.6;
}

/* Cards Grid */
.cards-section { padding: 20px 40px 60px; }

.cards-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
  gap: 20px;
  max-width: 1200px;
  margin: 0 auto;
}

/* Plant Card */
.plant-card {
  background: #fff;
  border-radius: var(--card-radius);
  overflow: hidden;
  box-shadow: 0 4px 20px rgba(0,0,0,0.07);
  cursor: pointer;
  transition: var(--transition);
  position: relative;
  border: 1px solid rgba(0,0,0,0.05);
}

.plant-card:hover {
  transform: translateY(-8px);
  box-shadow: 0 12px 30px rgba(0,0,0,0.12);
  border-color: var(--accent);
}

.plant-meta {
  display: flex;
  justify-content: space-between;
  margin-top: 15px;
  padding-top: 12px;
  border-top: 1px dashed rgba(0,0,0,0.1);
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 5px;
  font-size: 0.75rem;
  color: var(--text-soft);
  font-weight: 700;
}

.water-badge {
  position: absolute;
  top: 10px;
  right: 10px;
  padding: 5px 12px;
  border-radius: 12px;
  font-size: 0.7rem;
  font-weight: 800;
  z-index: 5;
  box-shadow: 0 4px 10px rgba(0,0,0,0.1);
}
.water-ok { background: #e8f0e0; color: var(--green-light); }
.water-due { background: var(--accent3); color: #fff; animation: pulse 2s infinite; }

.btn-water { background: #4a8c2a; color: #fff; border: none; padding: 5px 10px; border-radius: 8px; font-size: 0.75rem; cursor: pointer; margin-top: 5px; }

/* ═══════════════════════════════════════════
   NEW SECTIONS (ABOUT & CONTACT)
═══════════════════════════════════════════ */
.content-section { padding: 80px 40px; max-width: 1000px; margin: 0 auto; text-align: center; }
.content-section h2 { font-size: 2.5rem; margin-bottom: 20px; color: var(--green-dark); }
.content-section p { font-size: 1.1rem; line-height: 1.8; color: var(--text-soft); margin-bottom: 40px; }

.contact-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 40px; text-align: right; }
.contact-info { background: #fff; padding: 30px; border-radius: 20px; box-shadow: var(--shadow); }
.contact-form { display: flex; flex-direction: column; gap: 15px; }
.contact-form input, .contact-form textarea {
  padding: 15px; border-radius: 12px; border: 1px solid #ddd; font-family: inherit;
}

/* ═══════════════════════════════════════════
   FOOTER
═══════════════════════════════════════════ */
footer {
  background: var(--green-dark);
  color: #fff;
  padding: 60px 40px 20px;
  margin-top: auto;
}
.footer-grid {
  display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 40px;
  max-width: 1200px; margin: 0 auto 40px;
}
.footer-logo { font-size: 1.8rem; font-weight: 900; margin-bottom: 15px; }
.footer-links h4 { margin-bottom: 20px; color: var(--accent); }
.footer-links ul { list-style: none; }
.footer-links li { margin-bottom: 10px; color: rgba(255,255,255,0.7); cursor: pointer; transition: 0.2s; }
.footer-links li:hover { color: var(--accent); }
.footer-bottom {
  border-top: 1px solid rgba(255,255,255,0.1);
  padding-top: 20px; 
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 20px;
  font-size: 0.8rem; 
  color: rgba(255,255,255,0.5);
  flex-wrap: wrap;
}
.footer-bottom a {
  color: inherit;
  text-decoration: none;
  transition: var(--transition);
}
.footer-bottom a:hover { color: var(--accent); }

/* ═══════════════════════════════════════════
   NOTIFICATIONS
═══════════════════════════════════════════ */
#notification-container {
  position: fixed; bottom: 30px; left: 30px; z-index: 9999;
  display: flex; flex-direction: column; gap: 10px;
}
.toast {
  background: var(--green-dark); color: #fff; padding: 15px 25px;
  border-radius: 12px; box-shadow: 0 10px 20px rgba(0,0,0,0.2);
  display: flex; align-items: center; gap: 10px;
  animation: toastIn 0.4s ease forwards;
}
@keyframes toastIn { from { transform: translateX(-100%); opacity: 0; } to { transform: translateX(0); opacity: 1; } }

/* ═══════════════════════════════════════════
   MODAL STYLING
═══════════════════════════════════════════ */
.modal-overlay {
  position: fixed; inset: 0; background: rgba(0,0,0,0.7);
  backdrop-filter: blur(10px); z-index: 3000;
  display: none; align-items: center; justify-content: center;
  padding: 20px; transition: var(--transition);
}
.modal-overlay.active { display: flex; }
.modal-content {
  background: #fff; width: 100%; max-width: 450px;
  border-radius: 30px; padding: 40px; position: relative;
  box-shadow: 0 25px 50px -12px rgba(0,0,0,0.25);
  animation: modalSlideUp 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}
@keyframes modalSlideUp { from { opacity: 0; transform: translateY(40px); } to { opacity: 1; transform: translateY(0); } }
.close-modal {
  position: absolute; top: 25px; left: 25px;
  width: 35px; height: 35px; border-radius: 50%;
  border: none; background: #f0f5e8; color: var(--green-dark);
  cursor: pointer; display: flex; align-items: center; justify-content: center;
  font-weight: bold; transition: 0.2s;
}
.close-modal:hover { background: var(--accent); transform: rotate(90deg); }
.modal-body { text-align: center; }
.modal-body .icon { font-size: 4.5rem; display: block; margin-bottom: 10px; }
.modal-body h3 { font-size: 1.8rem; font-weight: 800; color: var(--green-dark); margin-bottom: 20px; }
.care-tips { text-align: right; list-style: none; }
.care-tips li {
  padding: 12px 0; border-bottom: 1px solid #f0f0f0;
  display: flex; gap: 12px; font-size: 0.95rem; line-height: 1.5;
}
.care-tips li::before { content: '✨'; }

/* الوضع الليلي - Dark Mode */
body.dark-mode {
  background: #0a1404;
  color: #f0f5e8;
}
body.dark-mode .plant-card,
body.dark-mode .modal-content,
body.dark-mode .contact-info,
body.dark-mode #myGardenSection {
  background: #152b0a !important;
  color: #f0f5e8;
}
body.dark-mode h2, body.dark-mode h3 { color: var(--accent) !important; }
body.dark-mode p, body.dark-mode .meta-item { color: rgba(255,255,255,0.7) !important; }
body.dark-mode .filter-btn { background: #1a3a0a; color: #fff; }
body.dark-mode .close-modal { background: #1a3a0a; color: var(--accent); }
body.dark-mode .care-tips li { border-bottom-color: rgba(255,255,255,0.1); }
body.dark-mode .search-input { background: #152b0a !important; color: #f0f5e8; border-color: rgba(255,255,255,0.1); }

#darkModeToggle { font-size: 1.2rem; display: flex; align-items: center; justify-content: center; width: 40px; }

</style>
</head>
<body>
    <nav id="mainNav">
        <a href="#" class="nav-logo" onclick="showPage('home')">
            <span class="logo-icon">🌿</span>
            <div class="logo-text">بستاني<span>.</span></div>
        </a>
        <ul class="nav-links">
            <li><button class="active" onclick="showPage('home')">الرئيسية</button></li>
            <li><button onclick="showPage('plants')">النباتات</button></li>
            <li><button onclick="showPage('about')">من نحن</button></li>
            <li><button id="darkModeToggle" onclick="toggleDarkMode()" title="تغيير المظهر">🌙</button></li>
            <li><button class="nav-cta" onclick="showPage('contact')">تواصل معنا</button></li>
        </ul>
    </nav>

    <!-- الصفحة الرئيسية -->
    <div id="home" class="page active">
        <section class="hero">
            <div class="hero-pattern"></div>
            <div class="hero-text">
                <div class="hero-badge">
                    <span class="pulse-dot"></span>
                    مجتمع مزارعي المنازل
                </div>
                <h1>ازرع <em>شغفك</em> في منزلك اليوم</h1>
                <p>اكتشف أسرار الزراعة المنزلية، من العناية بالنباتات الداخلية إلى إنشاء حديقة خضروات عضوية في شرفتك الخاصة.</p>
                <div class="hero-btns">
                    <button class="btn-primary" onclick="showPage('plants')">تصفح النباتات</button>
                    <button class="btn-secondary">دليل المبتدئين</button>
                </div>
                <div class="hero-stats">
                    <div class="stat">
                        <div class="stat-num">+50</div>
                        <div class="stat-label">نوع نبات</div>
                    </div>
                    <div class="stat">
                        <div class="stat-num">+10k</div>
                        <div class="stat-label">عضو نشط</div>
                    </div>
                </div>
            </div>
            <div class="hero-visual">
                <div class="hero-orbit">
                    <div class="orbit-center">🌱</div>
                    <div class="orbit-item">🍅</div>
                    <div class="orbit-item">🌿</div>
                    <div class="orbit-item">🍋</div>
                    <div class="orbit-item">🌶️</div>
                    <div class="orbit-item">🥬</div>
                    <div class="orbit-item">🌻</div>
                </div>
            </div>
        </section>

        <!-- قسم حديقتي الخاصة الجديد -->
        <section id="myGardenSection" class="cards-section" style="background: #fff; border-radius: 40px 40px 0 0; margin-top: -40px; position: relative; z-index: 10; border-bottom: 1px solid #eee;">
            <div class="page-header" style="background: none; padding: 60px 0 30px;">
                <h2 style="color: var(--green-dark); font-size: 2rem;">حديقتي <span>الخاصة</span></h2>
                <p style="color: var(--text-soft);">النباتات التي اخترت العناية بها في منزلك</p>
            </div>
            <div id="myGardenGrid" class="cards-grid"></div>
        </section>
    </div>

    <!-- صفحة من نحن -->
    <div id="about" class="page">
        <section class="content-section">
            <h2>قصة <span>بستاني</span></h2>
            <p>نحن مجتمع يهدف إلى تحويل كل شرفة ومنزل إلى واحة خضراء. نؤمن أن الزراعة ليست مجرد هواية، بل هي أسلوب حياة يعزز الصحة النفسية والبيئية.</p>
            <div class="hero-stats" style="border:none; justify-content:center;">
                <div class="stat"><div class="stat-num">2023</div><div class="stat-label">تاريخ التأسيس</div></div>
                <div class="stat"><div class="stat-num">+5k</div><div class="stat-label">حديقة منزلية</div></div>
            </div>
        </section>
    </div>

    <!-- صفحة اتصل بنا -->
    <div id="contact" class="page">
        <section class="content-section">
            <h2>يسعدنا <span>سماعك</span></h2>
            <p>لديك استفسار أو ترغب في مشاركة قصة نجاح حديقتك؟ فريقنا جاهز للرد عليك.</p>
            <div class="contact-grid">
                <div class="contact-info">
                    <h4>معلومات التواصل</h4>
                    <p>📸 <a href="https://www.instagram.com/jeet_plants?igsh=ajIwMHFqcHJtY3Zs" target="_blank" style="color: inherit; text-decoration: none;">انستقرام: jeet_plants</a></p>
                </div>
                <div class="contact-form">
                    <input type="text" placeholder="الاسم الكامل">
                    <input type="email" placeholder="البريد الإلكتروني">
                    <textarea placeholder="رسالتك..." rows="5"></textarea>
                    <button class="btn-primary" onclick="showToast('تم إرسال رسالتك بنجاح!')">إرسال الرسالة</button>
                </div>
            </div>
        </section>
    </div>

    <!-- صفحة النباتات -->
    <div id="plants" class="page">
        <header class="page-header">
            <h2>موسوعة <span>النباتات</span></h2>
            <p>كل ما تحتاجه لزراعة ناجحة ومستدامة</p>
        </header>
        
        <div class="search-container">
            <span class="search-icon">🔍</span>
            <input type="text" id="plantSearch" class="search-input" placeholder="ابحث عن نبات بالاسم...">
        </div>

        <div class="filter-tabs" id="filterContainer">
            <button class="filter-btn active" data-filter="all">الكل</button>
            <button class="filter-btn" data-filter="vegetable">خضروات</button>
            <button class="filter-btn" data-filter="herb">أعشاب</button>
            <button class="filter-btn" data-filter="ornamental">زينة</button>
        </div>

        <section class="cards-section">
            <div class="cards-grid" id="plantsGrid"></div>
        </section>
    </div>

    <!-- نافذة تفاصيل النبات -->
    <div id="plantModal" class="modal-overlay" onclick="if(event.target == this) closeModal()">
        <div class="modal-content">
            <button class="close-modal" onclick="closeModal()">✕</button>
            <div class="modal-body">
                <span class="icon" id="modalIcon">🌱</span>
                <h3 id="modalTitle">اسم النبات</h3>
                <ul class="care-tips" id="careTipsList">
                    <!-- يتم ملء النصائح برمجياً -->
                </ul>
                <button id="addToGardenBtn" class="btn-primary" style="margin-top: 25px; width: 100%;" onclick="addToGarden()">أضف إلى حديقتي</button>
            </div>
        </div>
    </div>

    <!-- تنبيهات النظام -->
    <div id="notification-container"></div>

    <footer>
        <div class="footer-grid">
            <div>
                <div class="footer-logo">بستاني<span>.</span></div>
                <p>موسوعتك الأولى للزراعة المنزلية والعناية بالنباتات.</p>
            </div>
            <div class="footer-links">
                <h4>روابط سريعة</h4>
                <ul>
                    <li onclick="showPage('home')">الرئيسية</li>
                    <li onclick="showPage('plants')">الموسوعة</li>
                    <li onclick="showPage('about')">من نحن</li>
                </ul>
            </div>
        </div>
        <div class="footer-bottom">
            <span>© 2024 بستاني - جميع الحقوق محفوظة</span>
            <a href="https://www.instagram.com/jeet_plants?igsh=ajIwMHFqcHJtY3Zs" target="_blank">📸 انستقرام: jeet_plants</a>
        </div>
    </footer>

    <script>
        const plantDetails = {
            tomato: { id: 'tomato', name: 'طماطم كرزية', icon: '🍅', category: 'vegetable', sun: '☀️ شمس كاملة', level: '🧠 متوسط', waterInterval: 1, desc: 'مثالية للشرفات، سهلة النمو وتنتج ثماراً حلوة.', tips: ['ري يومي صباحاً.', 'تقليم الأغصان الجانبية.', 'تسميد عند التزهير.'] },
            mint: { id: 'mint', name: 'نعناع بلدي', icon: '🌿', category: 'herb', sun: '⛅ ظل جزئي', level: '🌱 سهل جداً', waterInterval: 2, desc: 'سريع الانتشار، يحتاج لري منتظم ورائحة زكية.', tips: ['زراعة في أصيص منفصل.', 'تربة رطبة دائماً.', 'قص القمم النامية.'] },
            pepper: { id: 'pepper', name: 'فلفل حار', icon: '🌶️', category: 'vegetable', sun: '☀️ شمس كاملة', level: '🌱 سهل', waterInterval: 3, desc: 'يحب الحرارة ويضيف حيوية لحديقتك.', tips: ['شمس قوية 6 ساعات.', 'تقليل الري عند النضج.', 'دعم الساق بمركن.'] },
            cactus: { id: 'cactus', name: 'صبار زينة', icon: '🌵', category: 'ornamental', sun: '☀️ شمس قوية', level: '🌱 سهل جداً', waterInterval: 10, desc: 'يتحمل الجفاف بشكل مذهل ولا يحتاج رعاية مكثفة.', tips: ['ري متباعد جداً.', 'تربة رملية تصريف عالي.', 'تجنب الري الزائد.'] }
        };

        let myGarden = JSON.parse(localStorage.getItem('myGarden')) || []; // مصفوفة كائنات {id, lastWatered}
        let currentPlantId = null;

        // وظيفة لعرض النباتات في "حديقتي"
        function renderMyGarden() {
            const grid = document.getElementById('myGardenGrid');
            if (!grid) return;

            if (myGarden.length === 0) {
                grid.innerHTML = `<div style="grid-column: 1/-1; text-align: center; padding: 40px; color: var(--text-soft); font-weight: 600;">لم تضف أي نباتات إلى حديقتك بعد. تصفح الموسوعة وابدأ الآن!</div>`;
                return;
            }

            grid.innerHTML = myGarden.map(item => {
                const plant = plantDetails[item.id];
                const nextWaterDate = item.lastWatered + (plant.waterInterval * 24 * 60 * 60 * 1000);
                const isDue = Date.now() >= nextWaterDate;
                
                const daysLeft = Math.ceil((nextWaterDate - Date.now()) / (1000 * 60 * 60 * 24));
                const statusText = isDue ? 'حان وقت السقي! 💧' : `السقي بعد ${daysLeft} يوم`;
                const statusClass = isDue ? 'water-due' : 'water-ok';

                return `
                    <div class="plant-card">
                        <div class="water-badge ${statusClass}">${statusText}</div>
                        <div onclick="openPlantModal('${item.id}')" style="height: 150px; background: #e8f0e0; display:flex; align-items:center; justify-content:center; font-size: 3rem; cursor:pointer;">${plant.icon}</div>
                        <div style="padding: 15px;">
                            <h3 style="font-weight: 800; font-size: 1.1rem; margin-bottom:10px;">${plant.name}</h3>
                            <div style="display:flex; justify-content:space-between; align-items:center;">
                                <button onclick="removeFromGarden('${item.id}')" style="background:none; border:none; color:var(--accent3); font-size:0.7rem; cursor:pointer; font-weight:700;">إزالة ×</button>
                                <button onclick="waterPlant('${item.id}')" class="btn-water">سقيت النبات 💧</button>
                            </div>
                        </div>
                    </div>
                `;
            }).join('');
        }

        let currentFilter = 'all';
        let currentSearch = '';

        // وظيفة لعرض الموسوعة بالكامل مع الفلترة والبحث
        function renderEncyclopedia() {
            const grid = document.getElementById('plantsGrid');
            if (!grid) return;
            
            const plants = Object.values(plantDetails).filter(p => {
                const matchesFilter = currentFilter === 'all' || p.category === currentFilter;
                const matchesSearch = p.name.includes(currentSearch);
                return matchesFilter && matchesSearch;
            });
            
            if (plants.length === 0) {
                grid.innerHTML = `<div style="grid-column: 1/-1; text-align: center; padding: 40px; color: var(--text-soft); font-weight: 600;">عذراً، لم نجد نتائج لهذا البحث.</div>`;
                return;
            }

            grid.innerHTML = plants.map(p => `
                <div class="plant-card" onclick="openPlantModal('${p.id}')">
                    <div style="height: 180px; background: #e8f0e0; display:flex; align-items:center; justify-content:center; font-size: 3.5rem;">${p.icon}</div>
                    <div style="padding: 20px;">
                        <h3 style="margin-bottom: 8px; font-weight: 800;">${p.name}</h3>
                        <p style="font-size: 0.9rem; color: var(--text-soft); line-height: 1.5;">${p.desc}</p>
                        <div class="plant-meta">
                            <div class="meta-item">${p.sun}</div>
                            <div class="meta-item">${p.level}</div>
                        </div>
                    </div>
                </div>
            `).join('');
        }

        function showPage(pageId) {
            document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
            document.getElementById(pageId).classList.add('active');
            window.scrollTo(0, 0);
            
            document.querySelectorAll('.nav-links button').forEach(b => b.classList.remove('active'));
            if (event?.target?.tagName === 'BUTTON') event.target.classList.add('active');
        }

        function openPlantModal(id) {
            currentPlantId = id;
            const data = plantDetails[id];
            document.getElementById('modalIcon').innerText = data.icon;
            document.getElementById('modalTitle').innerText = data.name;
            const list = document.getElementById('careTipsList');
            list.innerHTML = data.tips.map(t => `<li>${t}</li>`).join('');

            // تحديث حالة الزر بناءً على ما إذا كان النبات في القائمة أم لا
            const btn = document.getElementById('addToGardenBtn');
            if (myGarden.some(item => item.id === id)) {
                btn.innerText = 'موجود في حديقتي ✓';
                btn.style.opacity = '0.7';
                btn.classList.add('btn-secondary');
                btn.classList.remove('btn-primary');
                btn.disabled = true;
            } else {
                btn.innerText = 'أضف إلى حديقتي';
                btn.style.opacity = '1';
                btn.classList.add('btn-primary');
                btn.classList.remove('btn-secondary');
                btn.disabled = false;
            }

            document.getElementById('plantModal').classList.add('active');
        }

        function addToGarden() {
            if (currentPlantId && !myGarden.some(item => item.id === currentPlantId)) {
                myGarden.push({ id: currentPlantId, lastWatered: Date.now() });
                localStorage.setItem('myGarden', JSON.stringify(myGarden));
                renderMyGarden();
                showToast(`تمت إضافة ${plantDetails[currentPlantId].name} إلى حديقتك! 🌿`);
                
                const btn = document.getElementById('addToGardenBtn');
                btn.innerText = 'تمت الإضافة بنجاح! ✨';
                btn.disabled = true;
                setTimeout(() => closeModal(), 1000);
            }
        }

        function waterPlant(id) {
            const index = myGarden.findIndex(item => item.id === id);
            if (index !== -1) {
                myGarden[index].lastWatered = Date.now();
                localStorage.setItem('myGarden', JSON.stringify(myGarden));
                renderMyGarden();
                showToast('تم تحديث موعد الري! 💧');
            }
        }

        function removeFromGarden(id) {
            myGarden = myGarden.filter(item => item.id !== id);
            localStorage.setItem('myGarden', JSON.stringify(myGarden));
            renderMyGarden();
            showToast('تمت الإزالة من الحديقة.');
        }

        function showToast(msg) {
            const container = document.getElementById('notification-container');
            const toast = document.createElement('div');
            toast.className = 'toast';
            toast.innerHTML = `<span>✨</span> ${msg}`;
            container.appendChild(toast);
            setTimeout(() => toast.remove(), 3000);
        }

        function closeModal() {
            document.getElementById('plantModal').classList.remove('active');
        }

        window.onscroll = function() {
            if (window.scrollY > 50) document.getElementById('mainNav').classList.add('scrolled');
            else document.getElementById('mainNav').classList.remove('scrolled');
        };

        // تفعيل أزرار الفلترة
        document.getElementById('filterContainer').addEventListener('click', (e) => {
            if (e.target.classList.contains('filter-btn')) {
                document.querySelectorAll('.filter-btn').forEach(btn => btn.classList.remove('active'));
                e.target.classList.add('active');
                currentFilter = e.target.dataset.filter;
                renderEncyclopedia();
            }
        });

        // تفعيل حقل البحث
        document.getElementById('plantSearch').addEventListener('input', (e) => {
            currentSearch = e.target.value.trim();
            renderEncyclopedia();
        });

        function toggleDarkMode() {
            document.body.classList.toggle('dark-mode');
            const isDark = document.body.classList.contains('dark-mode');
            localStorage.setItem('darkMode', isDark);
            document.getElementById('darkModeToggle').innerText = isDark ? '☀️' : '🌙';
        }

        // التشغيل الأولي عند تحميل الصفحة
        renderEncyclopedia();
        renderMyGarden();

        // استرجاع تفضيل الوضع الليلي
        if (localStorage.getItem('darkMode') === 'true') {
            document.body.classList.add('dark-mode');
            document.getElementById('darkModeToggle').innerText = '☀️';
        }
    </script>
</body>
</html>
